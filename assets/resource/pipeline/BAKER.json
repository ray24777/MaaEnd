            263,
            117
        ],
        "expected": [
            "会话消息"
        ],
        "next": [
            "BakerOpenFilter", // 只会执行一次, 后续走打开确认流程可以少一步
            "BakerExpend",
            "BakerOverCheck" // Baker 任务结束
        ]
    },
    "BakerCheckTask": {
        "desc": "事务通讯流程: 筛选已读条件后检测任务联系人是否可以互动",
        "recognition": "OCR",
        "roi": [
            0,
            0,
            263,
            117
        ],
        "expected": [
            "事务通讯"
        ],
        "next": [
            "BakerOpenFilter2", // 只会执行一次, 后续走打开确认流程可以少一步
            "BakerTalkWith", // 和会话信息流程相比不需要进行下拉
            "BakerTalkWithHint",
            "BakerOverCheck" // Baker 任务结束
        ]
    },
    "BakerOverCheck": {
        "desc": "检测到当前会话已经结束,尝试进入事务通讯流程。如果已经进入过了则直接退出",
