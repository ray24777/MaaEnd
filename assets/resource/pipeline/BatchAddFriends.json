        ]
    },
    "BatchAddFriendsUIDEnd": {
        "desc": "UID 列表模式结束",
        "recognition": "DirectHit",
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "BatchAddFriendsUIDFinishAction"
            }
        },
        "focus": {
            "Node.Action.Succeeded": "UID 添加结束"
        }
    },
    "BatchAddFriendsStrangersStart": {
