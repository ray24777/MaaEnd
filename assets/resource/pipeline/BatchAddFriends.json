{
    "BatchAddFriendsMain": {
        "desc": "批量添加好友主入口",
        "next": [
            "BatchAddFriendsOpenAddPage",
            "BatchAddFriendsOnAddPage",
            "[JumpBack]SceneEnterMenuFriends"
        ]
    },
    "BatchAddFriendsOpenAddPage": {
        "desc": "进入添加好友界面",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    620,
                    0,
                    200,
                    120
                ],
                "template": "BatchAddFriends/addFriend.png",
                "threshold": 0.8
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        },
        "next": [
            "BatchAddFriendsOnAddPage"
        ]
    },
    "BatchAddFriendsOnAddPage": {
        "desc": "确认已进入添加好友页面",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    63,
                    106,
                    50,
                    24
                ],
                "expected": "陌生人",
                "threshold": 0.7,
                "order_by": "Expected"
            }
        },
        "action": {
            "type": "DoNothing",
            "param": {}
        },
        "next": [
            "BatchAddFriendsStart"
        ]
    },
    "BatchAddFriendsSearchFlow": {
        "desc": "搜索流程入口",
        "recognition": "DirectHit",
        "next": [
            "BatchAddFriendsTriggerSearch"
        ]
    },
    "BatchAddFriendsTriggerSearch": {
        "desc": "点击搜索按钮",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    1067,
                    47,
                    160,
                    54
                ],
                "expected": [
                    "搜索"
                ],
                "threshold": 0.7,
                "order_by": "Expected"
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        },
        "next": [
            "BatchAddFriendsWaitSearchLoadingExit",
            "BatchAddFriendsSearchReady"
        ]
    },
    "BatchAddFriendsWaitSearchLoadingExit": {
        "desc": "等待搜索加载结束",
        "max_hit": 30,
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    529,
                    353,
                    253,
                    65
                ],
                "expected": "加载中",
                "threshold": 0.7,
                "order_by": "Expected"
            }
        },
        "action": {
            "type": "DoNothing",
            "param": {}
        },
        "post_wait_freezes": 1000,
        "next": [
            "BatchAddFriendsWaitSearchLoadingExit",
            "BatchAddFriendsSearchReady"
        ]
    },
    "BatchAddFriendsSearchReady": {
        "desc": "搜索就绪",
        "recognition": "DirectHit",
        "action": {
            "type": "DoNothing",
            "param": {}
        },
        "next": [
            "BatchAddFriendsHandleSearchResult"
        ]
    },
    "BatchAddFriendsClickAddButton": {
        "desc": "点击添加好友",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    1102,
                    139,
                    149,
                    495
                ],
                "expected": [
                    "添加好友"
                ],
                "threshold": 0.7,
                "order_by": "Expected"
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        },
        "post_wait_freezes": 200,
        "next": [
            "BatchAddFriendsFriendListFullToast",
            "BatchAddFriendsAfterAddEnd"
        ]
    },
    "BatchAddFriendsFriendListFullToast": {
        "desc": "好友列表已满提示",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    481,
                    108,
                    304,
                    29
                ],
                "expected": [
                    "好友列表已满",
                    "你的好友列表已满"
                ],
                "threshold": 0.7,
                "order_by": "Expected"
            }
        },
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "BatchAddFriendsFriendListFullAction"
            }
        },
        "next": [
            "BatchAddFriendsStrangersEnd",
            "BatchAddFriendsUIDEnd"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "好友列表已满，结束任务"
        }
    },
    "BatchAddFriendsAfterAddEnd": {
        "desc": "点击添加好友后结束",
        "recognition": "DirectHit",
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "BatchAddFriendsUIDOnAddAction"
            }
        },
        "next": [
            "BatchAddFriendsUIDLoopTop"
        ]
    },
    "BatchAddFriendsHasAddButtonStranger": {
        "desc": "存在添加好友按钮（陌生人列表）",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    1102,
                    139,
                    149,
                    495
                ],
                "expected": [
                    "添加好友"
                ],
                "threshold": 0.7,
                "order_by": "Expected"
            }
        },
        "action": {
            "type": "DoNothing",
            "param": {}
        },
        "next": [
            "BatchAddFriendsAddStrangersLoop",
            "BatchAddFriendsStrangersEnd"
        ]
    },
    "BatchAddFriendsClickAddButtonStranger": {
        "desc": "点击添加好友（陌生人列表）",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    1102,
                    139,
                    149,
                    495
                ],
                "expected": [
                    "添加好友"
                ],
                "threshold": 0.7,
                "order_by": "Expected"
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        },
        "post_wait_freezes": 200,
        "next": [
            "BatchAddFriendsFriendListFullToast",
            "BatchAddFriendsStrangersOnAdd"
        ]
    },
    "BatchAddFriendsStrangersOnAdd": {
        "desc": "陌生人添加进度",
        "recognition": "DirectHit",
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "BatchAddFriendsStrangersOnAddAction"
            }
        },
        "next": [
            "BatchAddFriendsStrangersStart",
            "BatchAddFriendsStrangersEnd"
        ]
    },
    "BatchAddFriendsSwipeList": {
        "desc": "陌生人列表向下滑",
        "recognition": "DirectHit",
        "action": {
            "type": "Swipe",
            "param": {
                "begin": [
                    640,
                    560
                ],
                "end": [
                    640,
                    220
                ],
                "end_hold": 200
            }
        },
        "post_wait_freezes": 500,
        "next": [
            "BatchAddFriendsStrangersAfterSwipe"
        ]
    },
    "BatchAddFriendsStrangersAfterSwipe": {
        "desc": "下滑后再次尝试添加，否则换一批",
        "recognition": "DirectHit",
        "next": [
            "BatchAddFriendsHasAddButtonStranger",
            "BatchAddFriendsChangeBatch",
            "BatchAddFriendsStrangersEnd"
        ]
    },
    "BatchAddFriendsHandleSearchResult": {
        "desc": "处理搜索结果",
        "recognition": "DirectHit",
        "next": [
            "BatchAddFriendsSearchUidNotFound",
            "BatchAddFriendsClickAddButton",
            "BatchAddFriendsSearchEmptyResult"
        ]
    },
    "BatchAddFriendsSearchUidNotFound": {
        "desc": "UID 不存在",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    537,
                    102,
                    209,
                    43
                ],
                "expected": [
                    "搜索的UID不存在"
                ],
                "threshold": 0.7,
                "order_by": "Expected"
            }
        },
        "next": [
            "BatchAddFriendsUIDLoopTop"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "UID 不存在，尝试下一个"
        }
    },
    "BatchAddFriendsSearchEmptyResult": {
        "desc": "搜索结果为空",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    591,
                    375,
                    121,
                    17
                ],
                "expected": "未搜索到相关玩家",
                "threshold": 0.7,
                "order_by": "Expected"
            }
        },
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "BatchAddFriendsUIDOnEmptyAction"
            }
        },
        "next": [
            "BatchAddFriendsUIDLoopTop"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "未搜索到相关玩家"
        }
    },
    "BatchAddFriendsUIDLoopTop": {
        "desc": "UID 列表循环入口",
        "recognition": "DirectHit",
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "BatchAddFriendsUIDLoopTopAction"
