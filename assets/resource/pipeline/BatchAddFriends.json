        },
        "next": [
            "BatchAddFriendsUIDLoopCounter",
            "BatchAddFriendsUIDEnd"
        ]
    },
    "BatchAddFriendsUIDLoopCounter": {
        "desc": "UID 列表循环计数",
        "max_hit": 20,
        "recognition": "DirectHit",
        "action": {
            "type": "DoNothing",
            "param": {}
        },
        "next": [
