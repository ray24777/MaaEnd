    "InMainWindow": {
        "desc": "[主流程·状态] 识别处于游戏主界面(非基建内)，用于流程结束或跳转判断",
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    {
                        "recognition": {
                            "type": "TemplateMatch",
                            "param": {
                                "roi": [
                                    172,
