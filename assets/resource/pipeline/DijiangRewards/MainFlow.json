    "GrayCancelButtonWithStop": {
        "desc": "特殊取消按钮，有文字，灰色底，X标志,最后会结束任务",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "GrayButtonBackground",
                    {
                        "recognition": {
                            "type": "TemplateMatch",
                            "param": {
                                "roi": "GrayButtonBackground",
                                "roi_offset": [
                                    -20,
                                    -20,
                                    80,
                                    40
                                ],
                                "template": [
                                    "Common/Button/CancelButtonType2.png",
                                    "Common/Button/CancelButtonType2Hover.png"
                                ],
                                "threshold": 0.9
                            }
                        }
                    }
                ],
                "box_index": 1
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": {
            "time": 80,
            "target": [
                0,
                0,
                0,
                0
            ]
        },
        "next": [
            "StopNode"
        ]
    },
    "LasCarbinColor": {
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": [
                    911,
                    417,
                    52,
                    218
                ],
                "method": 40,
                "lower": [
                    30,
                    100,
                    100
                ],
                "upper": [
                    40,
                    255,
                    255
                ],
                "connected": true,
                "count": 200
            }
        }
    },
    "LastCarbinText": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": "LasCarbinColor",
                "roi_offset": [
                    0,
                    0,
                    70,
                    0
                ],
                "expected": [
                    "培养舱"
                ],
                "only_rec": true
            }
        }
    },
    "InLastCarbin": {
        "desc": "[主流程·控制中枢] 识别已滑到最后一个培养舱且无红点，进入完成分支",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "LasCarbinColor",
                    "LastCarbinText"
                ]
            }
        },
