        ],
        "focus": {
            "Node.PipelineNode.Failed": "帝江基建流程结束后未能返回主界面"
        }
    },
    "CancelExit": {
        "desc": "[主流程·意外] 出现退出确认弹窗时点击取消，避免误退",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    308,
                    282,
                    370,
                    306
                ],
                "expected": [
                    "取消"
                ]
