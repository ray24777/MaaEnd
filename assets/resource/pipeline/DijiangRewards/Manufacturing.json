{
    "MFG_ReceiveRewards": {
        "doc": "[控制中枢·制造舱] 识别制造舱界面，领取奖励和补货",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    43,
                    0,
                    96,
                    64
                ],
                "expected": [
                    "制造舱"
                ]
            }
        },
        "focus": {
            "Node.PipelineNode.Failed": "制造舱领取奖励或补货流程失败"
        },
        "next": [
            "EntryMFGCarbinSuccess"
        ]
    },
    "EntryMFGCarbinSuccess": {
        "recognition": {
            "type": "And",
            "param": {
                "box_index": 1,
                "all_of": [
                    "InMFGCarbin",
                    "FacilityDetails"
                ]
            }
        },
        "next": [
            "MFGCarbinNeedTake",
            "MFGCarbinNeedReStock",
            "MFGCarbinNeedAssist",
            "Exit_MFG_Cabin"
        ]
    },
    "MFGCarbinNeedReStock": {
        "doc": "[制造舱·需要补货] 识别需要补货的奖励，点击补货",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    892,
                    437,
                    154,
                    118
                ],
                "template": [
                    "ClaimDijiangRewards/Restock.png"
                ],
                "order_by": "Vertical",
                "index": -1
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "MFGCarbinNeedReStockClose"
        ]
    },
    "MFGCarbinNeedReStockClose": {
        "doc": "[制造舱·需要补货] 点击补货完成界面确认按钮",
        "recognition": {
            "type": "And",
            "param": {
                "box_index": 1,
                "all_of": [
                    "WhiteConfirmButtonType1",
                    "WhiteButtonConfirmText"
                ]
            }
        },
        "action": "Click",
        "next": [
            "MFGCarbinNeedAssist",
            "Exit_MFG_Cabin"
        ]
    },
    "MFGCarbinNeedTake": {
        "doc": "[制造舱·需要领取] 识别需要领取的奖励，点击领取",
        "recognition": {
            "type": "And",
            "param": {
                "box_index": 1,
                "all_of": [
                    "YellowConfirmButtonType1",
                    "MFGCarbinNeedTakeText"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "MFGCarbinNeedTakeClose"
        ]
    },
    "MFGCarbinNeedTakeClose": {
        "doc": "[制造舱·需要领取] 点击领取完成界面确认按钮",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
