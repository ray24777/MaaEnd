                ]
            }
        },
        "action": "Click",
        "next": [
            "MFGCarbinNeedReStock",
            "MFGCarbinNeedAssist",
            "Exit_MFG_Cabin"
        ]
    },
    "MFGCarbinNeedAssist": {
        "doc": "[制造舱·需要助力] 识别需要助力的奖励，点击使用助力",
        "recognition": {
            "type": "And",
