{
    "EntryReceptionRoom": {
        "desc": "[会客室·进入] 主流程: 从控制中枢点击会客室区域进入",
        "max_hit": 1,
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    485,
                    0,
                    336,
                    260
                ],
                "expected": [
                    "^会客室$"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": {
            "time": 100,
            "timeout": 1000,
            "target": [
                662,
                543,
                309,
                48
            ]
        },
        "next": [
            "WaitEndExchange",
            "ReceptionRoom"
        ],
        "focus": {
            "Node.PipelineNode.Failed": "进入会客室识别"
        }
    },
    "WaitEndExchange": {
        "desc": "等待线索交流结束",
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    "EndExchange",
                    "EndExchangeCountDown"
                ]
            }
        },
        "next": [
            "EndExchange"
        ]
    },
    "EndExchange": {
        "desc": "[会客室·线索] 情报交流结束弹窗出现时点击确认结束",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "WhiteConfirmButtonType1",
                    "WhiteButtonConfirmText"
                ],
                "box_index": 1
            }
        },
        "action": "Click",
        "next": [
            "ReceptionRoom"
        ]
    },
    "ReceptionRoom": {
        "desc": "[会客室·状态] 确认已进入会客室界面，收集/领取/赠送和拜访线索",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    43,
                    0,
                    96,
                    64
                ],
                "expected": [
                    "会客室"
                ]
            }
        },
        "next": [
            "ReceptionRoomNeedCollectClues",
            "ReceptionRoomNeedReceiveClues",
            "[JumpBack]ReceptionRoomSetClues",
            "StartExchange",
            "ExitClueLibrary",
            "ExitReceptionRoom",
            "EndExchange"
        ],
        "focus": {
            "Node.PipelineNode.Failed": "进入会客室任务失败,未知界面"
        }
    },
    "StartExchange": {
        "desc": "[会客室·线索] 在会客室点击「开始线索交流」黄按钮",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "YellowConfirmButtonType1",
                    "StartExchangeText"
                ],
                "box_index": 1
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "CloseExchangeRewards"
        ]
    },
    "CloseExchangeRewards": {
