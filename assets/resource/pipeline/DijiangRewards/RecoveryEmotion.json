{
    "RecoveryEmotion": {
        "desc": "[控制中枢·恢复心情] 在总控中枢点击恢复心情红点，进入选择干员或关闭",
        "max_hit": 2,
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "InDijiangControlNexus",
                    "NeedAssistColor"
                ],
                "box_index": 1
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target_offset": [
                    -60,
                    10,
                    0,
                    0
                ]
            }
        },
        "post_wait_freezes": {
            "time": 80,
            "timeout": 1000
        },
        "next": [
            "RecoveryEmotionAssistUseAssist"
        ],
        "focus": {
            "Node.PipelineNode.Failed": "进入恢复心情界面后失败,未知界面"
        }
    },
    "RecoveryEmotionAssistUseAssist": {
        "desc": "[恢复心情·需要助力] 点击使用助力",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "YellowConfirmButtonType1",
                    "UseAssistText"
                ],
                "box_index": 1
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "StartRecoveryEmotion"
        ]
    },
    "EmotionFull": {
        "desc": "[恢复心情·意外] 点击了满心情/无法助力干员时的提示，返回控制中枢重新进入",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    416,
                    65,
                    428,
                    119
                ],
                "expected": [
                    "干员心情已满",
                    "无法使用助力"
                ]
            }
        },
        "next": [
            "BackToControlNexus"
        ],
        "focus": {
            "Node.PipelineNode.Failed": "处理满心情或无法助力提示失败"
        }
    },
    "StartRecoveryEmotion": {
        "desc": "[恢复心情·状态] 已打开「选择待恢复心情的干员」界面，开始选择待恢复心情的干员",
        "max_hit": 2,
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    464,
                    138,
                    278,
                    154
                ],
                "expected": [
                    "选择待恢复心情的干员"
                ]
            }
        },
        "next": [
            "EmotionFull",
            "CouldNotAssistEmotion",
            "[JumpBack]SelectLowEmotion"
        ]
    },
    "SelectLowEmotion": {
        "desc": "[恢复心情·操作] 在列表中识别心情条有空缺的干员并点击",
        "max_hit": 6,
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "EmotionIcon",
                    "EmotionBar",
                    "EmotionEmpty"
                ],
                "box_index": 2
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target_offset": [
                    -10,
                    -70,
                    -10,
                    0
                ]
            }
        }
    },
    "EmotionIcon": {
        "desc": "[恢复心情·状态] 心情图标位置",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    467,
                    236,
                    620,
                    282
                ],
                "template": [
                    "ClaimDijiangRewards/LowEmotion.png",
                    "ClaimDijiangRewards/NormalEmotion.png",
                    "ClaimDijiangRewards/HighEmotion.png"
                ],
                "order_by": "Vertical"
            }
        }
    },
    "EmotionBar": {
        "desc": "[恢复心情·状态] 心情条位置",
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": "EmotionIcon",
                "roi_offset": [
                    19,
                    7,
                    45,
                    -14
                ],
                "lower": [
                    255,
                    253,
                    253
                ],
                "upper": [
                    255,
                    253,
                    253
                ],
                "order_by": "Vertical"
            }
        }
    },
    "EmotionEmpty": {
        "desc": "[恢复心情·状态] 识别心情条空缺的干员",
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": "EmotionBar",
                "roi_offset": [
                    0,
                    0,
                    10,
                    0
                ],
                "lower": [
                    26,
                    26,
                    24
                ],
                "upper": [
                    27,
                    27,
                    25
                ],
                "connected": true,
                "count": 30,
                "order_by": "Vertical"
            }
        }
    },
    "CouldNotAssistEmotion": {
        "desc": "[恢复心情·收尾] 没有更多心情激励点数时的提示，返回控制中枢或关闭",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    432,
                    74,
                    428,
                    92
                ],
                "expected": [
                    "没有更多的心情激励点数"
                ]
            }
        },
        "next": [
            "ConfirmRecoveryEmotion"
        ],
        "focus": {
            "Node.PipelineNode.Failed": "没有更多心情激励点数提示处理失败"
        }
    },
    "ConfirmRecoveryEmotion": {
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "YellowConfirmButtonType1",
                    "YellowButtonConfirmText"
                ],
                "box_index": 1
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "CloseButtonType1"
        ]
    },
    "BackToControlNexus": {
        "desc": "[恢复心情·离开] 在恢复心情/助力等子界面点击左上返回按钮回到控制中枢",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    980,
                    102,
                    187,
                    82
                ],
                "template": [
                    "Resell/back.png"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "CloseButtonType1"
        ]
    }
}
