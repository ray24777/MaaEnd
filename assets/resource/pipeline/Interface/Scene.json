{
    // 只能使用本文件中定义的接口，禁止引用 SceneManager 文件夹内的 __ScenePrivate 节点
    "SceneAnyEnterWorld": {
        "doc": "从任意界面进入谷地/武陵/帝江任意一个大世界",
        "next": [
            "__ScenePrivateAnyEnterWorldSuccess",
            "[JumpBack]__ScenePrivateLogin",
            "[JumpBack]SceneDialogConfirm",
            "[JumpBack]__ScenePrivateEndVisitConfirm",
            "[JumpBack]SceneWaitLoadingExit",
            "[JumpBack]__ScenePrivateAnyExit"
        ]
    },
    "SceneEnterMapAny": {
        "doc": "从任意界面进入任意一个地图界面",
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "__ScenePrivateWorldEnterMapAny",
            "[JumpBack]SceneAnyEnterWorld"
        ]
    },
    "SceneEnterWorldFactory": {
        "doc": "从任意界面进入大世界工厂模式",
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "__ScenePrivateAnyEnterWorldFactorySuccess",
            "__ScenePrivateWorldFactoryDisableEnterFactoryActive",
            "__ScenePrivateWorldFactoryNotActiveEnterFactoryActive",
            "__ScenePrivateWorldDijiangEnterFactoryActive",
            "[JumpBack]SceneAnyEnterWorld"
        ]
    },
    "SceneDialogConfirm": {
        "doc": "点击对话框的确认按钮",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    {
                        "recognition": {
                            "type": "TemplateMatch",
                            "param": {
                                "roi": [
                                    290,
                                    360,
                                    670,
                                    210
                                ],
                                "template": [
                                    "SceneManager/DialogCancel.png"
                                ],
                                "threshold": 0.9
                            }
                        }
                    },
                    {
                        "recognition": {
                            "type": "TemplateMatch",
                            "param": {
                                "roi": [
                                    290,
                                    360,
                                    670,
                                    210
                                ],
                                "template": [
                                    "SceneManager/DialogConfirm.png"
                                ],
                                "threshold": 0.9
                            }
                        }
                    }
                ],
                "box_index": 1
            }
        },
        "action": {
            "type": "Click"
        }
    },
    "SceneDialogCancel": {
        "doc": "点击对话框的取消按钮",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    {
                        "recognition": {
                            "type": "TemplateMatch",
                            "param": {
                                "roi": [
                                    290,
                                    360,
                                    670,
                                    210
                                ],
                                "template": [
                                    "SceneManager/DialogCancel.png"
                                ],
                                "threshold": 0.9
                            }
                        }
                    },
                    {
                        "recognition": {
                            "type": "TemplateMatch",
                            "param": {
                                "roi": [
                                    290,
                                    360,
                                    670,
                                    210
                                ],
                                "template": [
                                    "SceneManager/DialogConfirm.png"
                                ],
                                "threshold": 0.9
                            }
                        }
                    }
                ],
                "box_index": 0
            }
        },
        "action": {
            "type": "Click"
        }
    },
    "SceneNoticeRewardsConfirm": {
        "doc": "点击奖励界面的确认按钮",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "InNoticeRewards",
                    "CloseRewardsButton"
                ],
                "box_index": 1
            }
        },
        "action": {
            "type": "Click"
        }
    },
    "SceneWaitLoadingExit": {
        "doc": "判断当前场景在加载界面，什么都不做，用于等待加载界面消失",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    0,
                    0,
                    200,
                    200
                ],
                "template": [
                    "SceneManager/LoadingIcon.png"
                ]
            }
        },
        "next": [
            "[JumpBack]SceneCheckYellowColor",
            "[JumpBack]SceneCheckTealColor",
            "[JumpBack]SceneCheckPurpleColor",
            "SceneWaitLoadingExit",
            "__ScenePrivateNextTrue"
        ]
    },
    "SceneCheckYellowColor": {
        "doc": "检查颜色准确性:黄色",
        "post_delay": 0,
        "pre_delay": 0,
        "rate_limit": 0,
        "max_hit": 1,
        "next": [
            "SceneCheckYellowColorSuccess",
            "SceneCheckYellowColorFailed",
            "EmptyNode"
        ]
    },
    "SceneCheckYellowColorSuccess": {
        "doc": "检查颜色准确性:黄色 成功",
        "post_delay": 0,
        "pre_delay": 0,
        "rate_limit": 0,
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": [
                    0,
                    480,
                    65,
                    85
                ],
                "method": 40,
                "upper": [
                    30,
                    255,
                    255
                ],
                "lower": [
                    30,
                    255,
                    1
                ]
            }
        }
    },
    "SceneCheckYellowColorFailed": {
        "doc": "检查颜色准确性:黄色 失败",
        "focus": {
            "Node.Recognition.Succeeded": "<span style=\"color: red; font-weight: bold;\">识别颜色失败:</span><span style=\"color: #807F00; font-weight: bold;\">黄色 (#807F00)</span>"
        },
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    0,
                    0,
                    200,
                    200
                ],
                "template": [
                    "SceneManager/LoadingIcon.png"
                ]
            }
        },
        "post_delay": 0,
        "pre_delay": 0,
        "rate_limit": 0,
        "next": [
            "SceneCheckColorFailedScreenShot"
