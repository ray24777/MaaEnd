            "type": "TemplateMatch",
            "param": {
                "roi": [
                    0,
                    0,
                    1280,
                    720
                ],
                "template": "CloseInfo/RightUpHand.png",
                "green_mask": true,
                "threshold": 0.66
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target_offset": [
                    30,
                    -25,
                    0,
                    0
                ]
            }
        },
        "post_wait_freezes": 200,
        "next": [
            "RealTimeTaskMain"
        ],
        "focus": {
            "Node.Action.Succeeded": "点击引导箭头"
