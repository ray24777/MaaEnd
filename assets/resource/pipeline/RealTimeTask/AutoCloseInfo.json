{
    // ========================================================
    // 任务 1：全屏阻断点击 (Priority: High)
    // ========================================================
    "CheckAnywhere": {
        "desc": "检测屏幕上出现的'点击任意处继续'提示",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    50,
                    25,
                    1150,
                    680
                ],
                "expected": [
                    "点击任意处继续",
                    "点击任意处",
                    "任意处继续"
                ]
            }
        },
        "next": [
            "Guard_CheckMailboxandClickToContinue",
            "RealTimeTaskMain"
        ]
    },
    "Guard_CheckMailboxandClickToContinue": {
        "desc": "后置拦截：如果检测到是邮箱界面，则跳过全屏点击，防止误触邮件内容,否则点击",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                // 只看左上角标题栏，非常高效且精准
                "roi": [
                    29,
                    9,
                    60,
                    80
                ],
                "template": "CloseInfo/MailHeader.png",
                // 这种静态UI非常标准，阈值可以拉高，防止误判
                "threshold": 0.8
            }
        },
        "inverse": true,
        "action": {
            "type": "Click",
            "param": {
                "target": [
                    1000,
                    600,
                    50,
                    50
                ]
            }
        },
        "next": [
            "RealTimeTaskMain"
        ],
        "focus": {
            "Node.Action.Succeeded": "跳过点击任意处继续"
        }
    },
    // ========================================================
    // 任务 2：特殊 UI 检测 (Priority: Medium)
    // ========================================================
    "CheckSpecialInfoPanel": {
        "desc": "检测并关闭特殊信息面板(档案/语音)",
        "recognition": "And",
        "all_of": [
            {
                "desc": "检测是否处于目标界面 (Or)",
                "recognition": "Or",
                "any_of": [
                    {
                        "desc": "检测档案界面",
                        "recognition": "TemplateMatch",
                        "roi": [
                            401,
                            87,
                            477,
                            36
                        ],
                        "template": "CloseInfo/DocHeader.png",
                        "threshold": 0.8
                    },
                    {
                        "desc": "检测语音界面",
                        "recognition": "TemplateMatch",
                        "roi": [
                            228,
                            127,
                            40,
                            471
                        ],
                        "template": "CloseInfo/VoiceBar.png",
                        "threshold": 0.8
                    }
                ]
            },
            {
                "desc": "识别退出按钮并获取其坐标",
                "recognition": "TemplateMatch",
                "roi": [
                    1050,
                    0,
                    230,
                    80
                ],
                "template": "CloseInfo/CloseButton.png",
                "threshold": 0.8
            }
        ],
        "action": {
            "type": "Click",
            "param": {
                "target": [
                    1230,
                    30
                ]
            }
        },
        "next": [
            "RealTimeTaskMain"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "识别到剧情文档/语音，准备关闭"
        }
    },
    // ========================================================
    // 任务 3：教程翻页 (Priority: Medium)
    // ========================================================
    "HandleTutorialPaging": {
        "desc": "识别说明书翻页箭头",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                // ROI 扩大：X 向左延伸到 1000，确保 16:10 也能包住
                "roi": [
                    1000,
                    250,
                    280,
                    200
                ],
                "template": "CloseInfo/TutorialNext.png",
                "threshold": 0.75
            }
        },
        "action": "Click",
        "post_wait_freezes": 100,
        "next": [
            "HandleTutorialConfirm",
            "RealTimeTaskMain"
        ],
        "focus": {
            "Node.Action.Succeeded": "点击说明书翻页"
        }
    },
    // ========================================================
    // 任务 4：教程确认 (Priority: Medium)
    // ========================================================
    "HandleTutorialConfirm": {
        "desc": "识别说明书底部的黄色确认按钮",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                // 稍微放宽一点点
                "roi": [
                    500,
                    600,
                    300,
                    100
                ],
                "template": "CloseInfo/TutorialConfirm.png",
                "threshold": 0.8
            }
        },
        "action": "Click",
        "post_wait_freezes": 100,
        "next": [
            "RealTimeTaskMain"
        ],
        "focus": {
            "Node.Action.Succeeded": "点击说明书确认键"
        }
    },
    // ========================================================
    // 任务 5：强制指引 (Priority: High)
    // ========================================================
    "HandleTutorialGuide_RightUp": {
        "desc": "检测并点击新手引导的指引箭头",
