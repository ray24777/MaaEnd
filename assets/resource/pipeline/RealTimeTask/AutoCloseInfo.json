                    640
                ],
                "template": "CloseInfo/LeftUpHand.png",
                "green_mask": true,
                "threshold": 0.66
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target_offset": [
                    -30,
                    -25,
                    0,
                    0
                ]
            }
        },
        "post_wait_freezes": 100,
        "next": [
            "RealTimeTaskMain"
