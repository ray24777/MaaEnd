                                    0,
                                    60,
                                    60
                                ],
                                "template": [
                                    "SceneManager/WorldFactoryNotActive.png"
                                ]
                            }
                        }
                    },
                    {
                        "recognition": {
                            "type": "TemplateMatch",
                            "param": {
                                "roi": [
                                    -200,
                                    0,
                                    200,
                                    200
                                ],
                                "template": [
                                    "SceneManager/WorldMenu.png"
                                ],
                                "green_mask": true
                            }
                        }
                    }
                ]
            }
        },
        "action": {
            "type": "ClickKey",
            "param": {
                "key": 9 // Tab
            }
