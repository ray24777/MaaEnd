        "desc": "在任意大世界界面，进入工厂模式",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    0,
                    0,
                    60,
                    60
                ],
                "template": [
                    "SceneManager/WorldFactoryNotActive.png",
                    "SceneManager/WorldFactoryActive.png"
                ],
                "threshold": 0.9
            }
        },
        "inverse": true,
        "next": [
