    "PriorStealGateProductionAndClueCheck": {
        "desc": "偷菜模式：助力生产和线索交流 - 剩余次数均大于0",
        "recognition": "And",
        "all_of": [
            "ProductionAssistOCR",
            "ClueExchangeOCR"
        ],
        "next": [
            "ProductionAssist"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "助力生产和线索交流剩余次数均大于0,进入偷菜模式"
        }
    },
    "ProductionAssistOCR": {
        "desc": "助力生产 - 剩余次数大于0",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    1221,
                    71,
                    14,
                    18
                ],
                "expected": [
                    "[1-5]"
                ],
                "threshold": 0.6
            }
        },
        "action": {
            "type": "DoNothing",
            "param": {}
