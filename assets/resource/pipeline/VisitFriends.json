{
    "FriendVisitMain": {
        "desc": "入口：优先识别当前界面，再决定按 Esc 后的行为（好友船 Esc→好友列表，己方世界 Esc→暂停菜单）",
        "next": [
            "OnFriendList",
            "OpenFriendList",
            "OpenFriendListFromFriendShip",
            "EnterPauseMenu",
            "[JumpBack]SceneEnterMenuFriends"
        ]
    },
    "OpenFriendListFromFriendShip": {
        "desc": "在好友船上时按 Esc 会打开好友列表（而非暂停菜单），按下 Esc 后进入好友列表",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    1166,
                    0,
                    114,
                    76
                ],
                "template": "VisitFriends/ArriveShip.png",
                "threshold": 0.8
            }
        },
        "action": {
            "type": "ClickKey",
            "param": {
                "key": 27
            }
        },
        "post_wait_freezes": 2,
        "next": [
            "OnFriendList"
        ]
    },
    "EnterPauseMenu": {
        "desc": "在己方世界按下 Esc 唤出暂停界面，等待「好友」按钮（仅在非好友船时有效）",
        "max_hit": 1,
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "InWorld"
                ],
                "box_index": 0
            }
        },
        "action": {
            "type": "ClickKey",
            "param": {
                "key": 27
            }
        },
        "post_delay": 400,
        "next": [
            "OpenFriendList"
        ]
    },
    "OpenFriendList": {
        "desc": "发现「好友」按钮，按下",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    898,
                    62,
                    382,
                    612
                ],
                "template": "VisitFriends/FriendList.png",
                "threshold": 0.8
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        },
        "next": [
            "OnFriendList"
        ]
    },
    "OnFriendList": {
        "desc": "识别是否位于好友列表界面",
