    "ProductionAssistSwipe": {
        "desc": "好友界面向下滑找更多好友",
        "max_hit": 100,
        "recognition": "Or",
        "any_of": [
            "ProductionAssistOCR",
            "ClueExchangeOCR"
        ],
        "action": {
            "type": "Swipe",
            "param": {
                "begin": [
                    670,
                    560
                ],
                "end": [
                    670,
                    200
                ],
                "end_hold": 200
            }
        },
        //理论上好友列表滑到底也不一定能找到能助力的，设置较大重试次数,且如果没有助力和线索次数会跳过该节点,如果不设定max_hit可能会无限重试
        //后面有go大手子可以重构这里,比如成功一次助力和线索就重置max_hit,或者滑到底后识别到底了再停止重试
        "next": [
            "ProductionAssist"
        ]
    },
    "VisitorTerminalSwipeFacilityList": {
        "desc": "访客终端界面为了露出培养仓助力按钮而向左划。post_wait_freezes 用于等待滑动动画结束、界面回位后再识别下一节点，避免动画未结束时误判",
        "recognition": "DirectHit",
        "action": {
            "type": "Swipe",
            "param": {
                "begin": [
                    1000,
                    550
                ],
                "end": [
                    550,
                    550
                ],
                "end_hold": 200
            }
        },
        "post_wait_freezes": 500,
        "next": [
