{
    // 自动转交运送委托
    "DeliveryJobsMain": {
        "desc": "开始自动转交运送委托",
        "next": [
            "DeliveryJobsLoop"
        ]
    },
    "DeliveryJobsLoop": {
        "desc": "主循环，仅支持从地区建设界面开始",
        "recognition": "And",
        "all_of": [
            "InRegionalDevelopment"
        ],
        "next": [
            "DeliveryJobsAuto",
            "DeliveryJobsValleyIV",
            "DeliveryJobsWuling",
            "DeliveryJobsFinished"
        ]
    },
    "DeliveryJobsAuto": {
        "desc": "自动选择起始地区运送委托",
        "max_hit": 1,
        "next": [
            "DeliveryJobsAutoValleyIV",
            "DeliveryJobsAutoWuling"
        ]
    },
    "DeliveryJobsAutoValleyIV": {
        "desc": "自动选择四号谷地运送委托",
        "recognition": "Or",
        "any_of": [
            "InValleyIVRegionalDevelopment",
            "InValleyIVLocalDepotNode"
        ],
        "next": [
            "DeliveryJobsValleyIV",
            "DeliveryJobsLoop"
        ]
    },
    "DeliveryJobsAutoWuling": {
        "desc": "自动选择武陵运送委托",
        "recognition": "Or",
        "any_of": [
            "InWulingRegionalDevelopment",
            "InWulingLocalDepotNode"
        ],
        "next": [
            "DeliveryJobsWuling",
            "DeliveryJobsLoop"
        ]
    },
    "DeliveryJobsValleyIV": {
        "desc": "四号谷地运送委托",
        "max_hit": 1,
        "next": [
            "[JumpBack]DeliveryJobsEnterDeliveryJob",
            "[JumpBack]DeliveryJobsEnterOriginiumScienceParkCargo",
            "[JumpBack]DeliveryJobsEnterOriginLodespringCargo",
            "[JumpBack]DeliveryJobsEnterPowerPlateauCargo",
            "DeliveryJobsValleyIVCargoNotReady",
            "DeliveryJobsCheckValleyIVDepotLocked",
            "[JumpBack]DeliveryJobsGoToValleyIVDepot"
        ]
    },
    "DeliveryJobsWuling": {
        "desc": "武陵运送委托",
        "max_hit": 1,
        "next": [
            "[JumpBack]DeliveryJobsEnterDeliveryJob",
            "[JumpBack]DeliveryJobsEnterWulingCityCargo",
            "DeliveryJobsWulingCargoNotReady",
            "DeliveryJobsCheckWulingDepotLocked",
            "[JumpBack]DeliveryJobsGoToWulingDepot"
        ]
    },
    "DeliveryJobsFinished": {
        "desc": "自动转交运送委托完成。这个节点主要是为了调试界面看起来舒服"
    }
}
