{
    // 送货任务进入仓储节点的流程
    // 先判断具体在哪个界面
    "DeliveryJobsGoToDepot": {
        "desc": "前往指定仓储节点",
        "next": [
            "[Anchor]DeliveryJobsInDepotNode",
            "[Anchor]DeliveryJobsEnterDepot",
            "DeliveryJobsEnterDepot",
            "[JumpBack]RegionalDevelopmentButton"
        ]
    },
    "DeliveryJobsEnterDepot": {
        "desc": "进入指定仓储节点，通过锚点设置",
        "recognition": "And",
        "all_of": [
            "InRegionalDevelopment"
        ],
        "next": [
            "[Anchor]DeliveryJobsInDepotNode",
            "[Anchor]DeliveryJobsEnterDepot",
            "[JumpBack][Anchor]DeliveryJobsGoToRegion"
        ]
    },
    "DeliveryJobsGoToValleyIVDepot": {
        "desc": "进入四号谷地仓储节点",
        "anchor": {
            "DeliveryJobsInDepotNode": "InValleyIVLocalDepotNode",
            "DeliveryJobsEnterDepot": "DeliveryJobsEnterValleyIVDepot",
            "DeliveryJobsGoToRegion": "GoToValleyIV"
        },
        "next": [
            "DeliveryJobsGoToDepot"
        ]
    },
    "DeliveryJobsGoToWulingDepot": {
        "desc": "进入武陵仓储节点",
        "anchor": {
            "DeliveryJobsInDepotNode": "InWulingLocalDepotNode",
            "DeliveryJobsEnterDepot": "DeliveryJobsEnterWulingDepot",
            "DeliveryJobsGoToRegion": "GoToWuling"
        },
        "next": [
            "DeliveryJobsGoToDepot"
        ]
    },
    "DeliveryJobsEnterValleyIVDepot": {
        "desc": "进入四号谷地仓储节点",
        "recognition": "And",
        "all_of": [
            "DepotButton",
            "InValleyIVRegionalDevelopment"
        ],
        "action": "Click",
        "next": [
            "InValleyIVLocalDepotNode"
        ]
    },
    "DeliveryJobsEnterWulingDepot": {
        "desc": "进入武陵仓储节点",
        "recognition": "And",
        "all_of": [
            "DepotButton",
            "InWulingRegionalDevelopment"
        ],
        "action": "Click",
        "next": [
            "InWulingLocalDepotNode"
        ]
    },
    "DeliveryJobsDepotLocked": {
        "desc": "仓储节点未解锁",
        "recognition": "TemplateMatch",
        "roi": [
            1179,
            347,
            36,
            47
        ],
        "template": "DeliveryJobs/DepotLocked.png",
        "threshold": 0.8
    },
    "DeliveryJobsCheckValleyIVDepotLocked": {
        "desc": "检查四号谷地仓储节点是否解锁，如果未解锁则直接跳出，去下一个区域",
        "recognition": "And",
        "all_of": [
            "DeliveryJobsDepotLocked",
            "InValleyIVRegionalDevelopment"
        ],
        "next": [
            "DeliveryJobsLoop"
        ],
        "focus": {
            "Node.Action.Starting": "$task.DeliveryJobs.ValleyIVDepotLocked"
        }
    },
    "DeliveryJobsCheckWulingDepotLocked": {
        "desc": "检查武陵仓储节点是否解锁，如果未解锁则直接跳出，去下一个区域",
        "recognition": "And",
        "all_of": [
            "DeliveryJobsDepotLocked",
            "InWulingRegionalDevelopment"
        ],
        "next": [
            "DeliveryJobsLoop"
        ],
        "focus": {
            "Node.Action.Starting": "$task.DeliveryJobs.WulingDepotLocked"
        }
    }
}
