{
    "EssenceFilterMain": {
        "desc": "入口点",
        "next": [
            "EssenceFilterCheckInInventory"
        ],
        "on_error": "EssenceFilterMainFailed"
    },
    "EssenceFilterMainFailed": {
        "desc": "入口点失败",
        "action": {
            "type": "DoNothing"
        },
        "next": [
            "EssenceFilterFinish"
        ],
        "focus": {
            "Node.Action.Failed": "未能进入基质界面，结束任务"
        }
    },
    "EssenceFilterCheckInInventory": {
        "desc": "检查是否在背包Essence页",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    20,
                    46,
                    74,
                    30
                ],
                "template": "EssenceFilter/EssenceSlot.png",
                "threshold": 0.8
            }
        },
        "timeout": 2000,
        "next": [
            "FirstSwipeToTop"
        ],
        "on_error": [
            "EssenceFilterNavigateToInventory"
        ],
        "focus": {
            "Node.Action.Succeeded": "确认在基质界面"
        }
    },
    "FirstSwipeToTop": {
        "desc": "初始化位置，滑动到顶端",
        "action": {
            "type": "Swipe",
            "param": {
                "begin": [
                    500,
                    100
                ],
                "end": [
                    500,
                    500
                ],
                "end_hold": 5,
                "duration": 100
            }
        },
        "repeat": 3,
        "post_delay": 500,
        "next": [
            "EssenceFilterInit"
        ],
        "focus": {
            "Node.Action.Succeeded": "滑动到顶端"
        }
    },
    "EssenceFilterNavigateToInventory": {
        "desc": "导航",
        "action": "DoNothing",
        "next": [
            "EssenceFilterFinish"
        ],
        "focus": {
            "Node.Action.Succeeded": "不在基质界面"
        }
    },
    "EssenceFilterInit": {
        "desc": "初始化：加载数据与预设",
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "EssenceFilterInitAction"
            }
        },
        "post_wait_freezes": {
            "time": 50,
            "target": [
                38,
                398,
                922,
                198
            ]
        },
        "next": [
            "OCREssenceInventoryNumber",
            "EssenceRowDetect",
            "EssenceDetectFinal",
            "EssenceFilterFinish"
        ],
        "focus": {
            "Node.Action.Succeeded": "初始化完成"
        }
    },
    "OCREssenceInventoryNumber": {
        "desc": "OCR 识别背包中的基质数量",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    93,
                    48,
                    74,
                    22
                ],
                "expected": [
                    "\\d+(\\/\\d+)?"
                ],
                "only_rec": true,
                "threshold": 0.3
            }
        },
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "OCREssenceInventoryNumberAction"
            }
        },
        "timeout": 1500,
        "rate_limit": 300,
        "next": [
            "EssenceRowDetect",
            "EssenceDetectFinal",
            "EssenceFilterFinish"
        ]
    },
    "EssenceRowDetect": {
        "desc": "整行模板匹配，收集所有格子",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    18,
                    72,
                    956,
                    119
                ],
                "template": "EssenceFilter/EssenceGeneral.png",
                "method": 5,
                "threshold": 0.35
            }
        },
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "EssenceFilterRowCollectAction"
            }
        },
        "next": [
            "EssenceFilterRowNextItem",
            "EssenceDetectFinal"
        ]
    },
    "EssenceDetectFinal": {
        "desc": "尾扫：扩大 ROI 捕获底部剩余行",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    18,
                    72,
                    956,
                    570
                ], // 高度放大，覆盖底部区域
                "template": "EssenceFilter/EssenceGeneral.png",
                "method": 5,
                "threshold": 0.35
            }
        },
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "EssenceFilterRowCollectAction"
            }
        },
        "next": [
            "EssenceFilterRowNextItem"
        ]
    },
