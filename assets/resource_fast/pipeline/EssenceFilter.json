            "type": "DirectHit",
            "param": {}
        },
        "action": {
            "type": "DoNothing"
        },
        "next": [
            "EssenceFilterRowNextItem"
        ],
        "focus": {
            "Node.Action.Failed": "OCR 超时：跳过"
        }
    },
    "EssenceFilterSkillDecision": {
        "desc": "匹配技能并决定是否上锁",
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "EssenceFilterSkillDecisionAction"
            }
        },
        "next": [
            "EssenceFilterRowNextItem"
        ]
    },
    "EssenceFilterLockItemLog": {
        "desc": "日志：即将锁定Essence",
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "EssenceFilterTraceAction",
                "custom_action_param": {
                    "step": "LockItem"
                }
            }
        },
        "next": [
            "EssenceFilterCheckLocked",
            "EssenceFilterLockItem"
        ]
    },
    "EssenceFilterLockItem": {
        "desc": "锁定Essence",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    1217,
                    180,
                    21,
                    21
                ],
                "template": "EssenceFilter/LockButton.png",
                "threshold": 0.9
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 300,
        "next": [
            "EssenceFilterCheckLocked",
            "EssenceFilterLockItem"
        ],
        "focus": {
            "Node.Action.Succeeded": "已锁定基质"
        }
    },
    "EssenceFilterCheckLocked": {
        "desc": "确认已上锁",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    1217,
                    180,
                    21,
                    21
                ],
                "template": "EssenceFilter/LockButtonLocked.png",
                "threshold": 0.9
            }
        },
        "next": [
            "EssenceFilterRowNextItem"
        ],
        "on_error": [
            "EssenceFilterLockItem"
        ],
        "focus": {
            "Node.Action.Succeeded": "已确认上锁"
        }
    },
