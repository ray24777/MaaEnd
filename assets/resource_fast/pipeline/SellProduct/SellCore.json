{
    "SellProductAtSell": {
        "focus": {
            "Node.Recognition.Succeeded": "已进入售卖界面"
        },
        "doc": "位于出售页面",
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    // 交易
                    "交易",
                    "交易",
                    "Trade",
                    "取引",
                    "거래",
                    // 据点上限
                    "据点上限",
                    "據點上限",
                    "current limit",
                    "上限",
                    "거점 발전 포인트 현재 거점 최대치 도달",
                    // 不足
                    "不足",
                    "不足",
                    "Insufficient",
                    "insufficient",
                    "不足",
                    "거점 관리권 보유량 부족"
                ],
                "roi": [
                    900,
                    550,
                    350,
                    150
                ]
            }
        },
        "next": [
            "SellProductCanSell"
        ]
    },
    "SellProductCanSell": {
        "doc": "判断当前能不能出售的虚节点",
        "next": [
            "SellProductZeroProduct",
            "SellProductZeroMoney",
            "SellProductClickBarRight",
            "SellProductDragBar"
        ]
    },
    "SellProductZeroProductColorMatch": {
        "doc": "识别红色文字判断是否有货",
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": [
                    1083,
                    327,
                    109,
                    24
                ],
                "method": 40,
                "lower": [
                    0,
                    30,
                    80
                ],
                "upper": [
                    5,
                    150,
                    200
                ],
                "count": 10
            }
        }
    },
    "SellProductWhiteTextPosition": {
        "doc": "识别白色文字位置，判断是否有货",
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": [
                    1083,
                    327,
                    109,
                    24
                ],
                "method": 4,
                "lower": [
                    190,
                    190,
                    190
                ],
                "upper": [
                    255,
                    255,
                    255
                ],
                "count": 10
            }
        }
    },
    "SellProductZeroProduct": {
        "doc": "货物数量不足，先尝试更换货品，失败则换据点",
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    "SellProductZeroProductColorMatch",
                    {
                        "recognition": {
                            "type": "And",
                            "param": {
                                "all_of": [
                                    "SellProductWhiteTextPosition",
                                    {
                                        "recognition": {
                                            "type": "OCR",
                                            "param": {
                                                "roi": "SellProductWhiteTextPosition",
                                                "expected": [
                                                    "^[0-9]{1,3}$"
                                                ],
                                                "only_rec": true
                                            }
                                        }
                                    }
                                ]
                            }
                        }
                    }
                ]
            }
        },
        "next": [
            "SellProductChangeProduct",
            "SellProductOutpostDone"
        ]
    },
    "SellProductZeroMoney": {
        "focus": {
            "Node.Action.Succeeded": "该据点调度券不足，过一会再来吧"
        },
        "doc": "调度券余量为0",
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    // 不足
                    "不足",
                    "不足",
                    "Insufficient",
                    "insufficient",
                    "不足",
                    "거점 관리권 보유량 부족"
                ],
                "roi": [
                    900,
                    611,
                    350,
                    77
                ]
            }
        },
        "next": [
            "SellProductOutpostDone"
        ]
    },
    "SellProductChangeProduct": {
        "doc": "识别更换货品并点击，进入更换UI",
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    // 更换货品
                    "更换货品",
                    "更換貨品",
                    "Switch Goods",
                    "商品変更",
                    "상품 교체"
                ],
                "roi": [
                    1115,
                    344,
                    172,
                    149
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        },
        "next": [
            "SellProductSelectNewProduct"
        ]
    },
    "SellProductSelectNewProduct": {
        "doc": "在更换UI中识别新货物并点击",
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    // 本地仓储
                    "本地仓储",
                    "本地區倉儲",
                    "Local Depot",
                    "地域在庫",
                    "지역 저장고"
                ],
                "roi": [
                    511,
                    180,
                    274,
                    83
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        },
        "next": [
            "SellProductSelectNewProductConfirm"
        ]
    },
    "SellProductSelectNewProductConfirm": {
        "doc": "点击确认",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "WhiteConfirmButtonType2"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        },
        "next": [
            "SellProductCanSellAfterChange"
        ]
    },
    "SellProductClickBarRight": {
        "doc": "点击进度条最右侧",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "method": 10001,
                "template": [
                    "SellProduct/SellProductBarRight.png"
                ],
                "roi": [
                    1115,
                    507,
                    88,
                    103
                ]
            }
        },
        "pre_wait_freezes": 100,
        "action": {
            "type": "Click",
            "param": {
                "target_offset": [
                    40,
                    21,
                    -30,
                    -43
                ]
            }
        },
        // 单击后如果马上单击交易会出问题，不懂为啥
        "post_wait_freezes": {
            "time": 200,
            "target": [
                1210,
                554,
                45,
                39
            ]
        },
        "next": [
            "SellProductZeroProduct",
            "SellProductZeroMoney",
            "SellProductSell"
        ]
    },
    "SellProductDragBar": {
        "doc": "备选方案-滑动滑动条",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "method": 10001,
                "template": [
                    "SellProduct/SellProductBar.png"
                ],
                "roi": [
                    1000,
                    500,
                    200,
                    150
                ]
            }
        },
        "pre_wait_freezes": 100,
        "action": {
            "type": "Swipe",
            "param": {
                "end_offset": [
                    [
                        0,
                        0,
                        400,
                        0
                    ]
                ],
                "duration": [
                    500
                ]
            }
        },
        "next": [
            "SellProductZeroProduct",
            "SellProductZeroMoney",
            "SellProductSell"
        ]
    },
    "SellProductSell": {
        "doc": "交易",
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    // 交易
                    "交易",
                    "交易",
                    "Trade",
                    "trade",
                    "取引",
                    "거래"
                ],
                "roi": [
                    1000,
                    640,
                    250,
                    100
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        },
        "post_wait_freezes": {
            "time": 200,
            "target": [
                533,
                300,
                213,
                103
            ]
        },
        "next": [
            "SellProductSellCheck"
        ]
    },
    "SellProductSellCheck": {
        "doc": "交易后确认",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "CloseRewardsButton",
                    {
                        "recognition": {
                            "type": "TemplateMatch",
                            "param": {
                                "template": [
                                    "SellProduct/SellProductCheckHeader.png"
                                ],
                                "roi": [
                                    577,
                                    10,
                                    138,
                                    118
                                ]
                            }
                        }
                    }
                ]
            }
        },
        "post_wait_freezes": 100,
        "action": {
            "type": "Click",
            "param": {}
        },
        "next": [
            "SellProductSellCheckComplete"
        ]
    },
    "SellProductSellCheckComplete": {
        "doc": "交易完成，奖励界面已关闭",
        "focus": {
            "Node.Action.Succeeded": "成功完成一次交易"
        },
        "next": [
            "SellProductCanSellAfterChange"
        ]
    },
    "SellProductOutpostDone": {
        "doc": "虚节点：这个据点已经被售卖完毕",
        "next": [
            "[Anchor]SellProductNextOutpost"
        ]
    },
    "SellProductNextOutpost": {
        "doc": "虚节点：通用切换节点，由各据点At节点通过anchor指定目标"
    },
    "SellProductBackToRegionalConstruction": {
        "doc": "返回区域建设界面",
        "recognition": "And",
        "all_of": [
            "CloseButtonType1"
        ],
        "action": "Click",
        "next": [
            "SellProductAtDevelopment"
        ]
    }
}
