{
    "task": [
        {
            "name": "DeliveryJobs",
            "label": "$task.DeliveryJobs.label",
            "entry": "DeliveryJobsMain",
            "description": "$task.DeliveryJobs.description",
            "option": [
                "ValleyIV",
                "Wuling",
                "PackCargoSelectItem"
            ]
        }
    ],
    "option": {
        "ValleyIV": {
            "type": "switch",
            "label": "$global.region.ValleyIV",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "DeliveryJobsValleyIV": {
                            "enabled": true
                        }
                    },
                    "option": [
                        "OriginiumSciencePark",
                        "OriginLodespring",
                        "PowerPlateau"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "DeliveryJobsValleyIV": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "OriginiumSciencePark": {
            "type": "switch",
            "label": "$global.region.OriginiumSciencePark",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "DeliveryJobsEnterOriginiumScienceParkCargo": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "DeliveryJobsEnterOriginiumScienceParkCargo": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "OriginLodespring": {
            "type": "switch",
            "label": "$global.region.OriginLodespring",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "DeliveryJobsEnterOriginLodespringCargo": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "DeliveryJobsEnterOriginLodespringCargo": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "PowerPlateau": {
            "type": "switch",
            "label": "$global.region.PowerPlateau",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "DeliveryJobsEnterPowerPlateauCargo": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "DeliveryJobsEnterPowerPlateauCargo": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "Wuling": {
            "type": "switch",
            "label": "$global.region.Wuling",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "DeliveryJobsWuling": {
                            "enabled": true
                        }
                    },
                    "option": [
                        "WulingCity"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "DeliveryJobsWuling": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "WulingCity": {
            "type": "switch",
            "label": "$global.region.WulingCity",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "DeliveryJobsEnterWulingCityCargo": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "DeliveryJobsEnterWulingCityCargo": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "PackCargoSelectItem": {
            "type": "switch",
            "label": "$task.DeliveryJobs.PackCargoSelectItem.label",
            "description": "$task.DeliveryJobs.PackCargoSelectItem.description",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "DeliveryJobsSelectTypeOfGoodsToPackNextStep": {
                            "next": [
                                "[Anchor]DeliveryJobsSelectItemToFill"
                            ]
                        }
                    },
                    "option": [
                        "WhatToFillValleyIV",
                        "WhatToFillWuling"
                    ]
                },
                {
                    "name": "No"
                }
            ],
            "default_case": "No"
        },
        "WhatToFillValleyIV": {
            "type": "select",
            "label": "$task.DeliveryJobs.WhatToFillValleyIV",
            "cases": [
                {
                    "name": "砂叶粉末",
                    "label": "$item.SandleafPowder",
                    "pipeline_override": {
                        "DeliveryJobsSelectItemToFillValleyIV": {
                            "template": "DeliveryJobs/SandleafPowder.png"
                        }
                    }
                },
                {
                    "name": "荞花粉末",
                    "label": "$item.BuckflowerPowder",
                    "pipeline_override": {
                        "DeliveryJobsSelectItemToFillValleyIV": {
                            "template": "DeliveryJobs/BuckflowerPowder.png"
                        }
                    }
                },
                {
                    "name": "柑实粉末",
                    "label": "$item.CitromePowder",
                    "pipeline_override": {
                        "DeliveryJobsSelectItemToFillValleyIV": {
                            "template": "DeliveryJobs/CitromePowder.png"
                        }
                    }
                },
                {
                    "name": "酮化灌木粉末",
                    "label": "$item.AketinePowder",
                    "pipeline_override": {
                        "DeliveryJobsSelectItemToFillValleyIV": {
                            "template": "DeliveryJobs/AketinePowder.png"
                        }
                    }
                }
            ],
            "default_case": "砂叶粉末"
        },
        "WhatToFillWuling": {
            "type": "select",
            "label": "$task.DeliveryJobs.WhatToFillWuling",
            "cases": [
                {
                    "name": "芽针",
                    "label": "$item.Yazhen",
                    "pipeline_override": {
                        "DeliveryJobsSelectItemToFillWuling": {
                            "template": "DeliveryJobs/Yazhen.png"
                        }
                    }
                },
                {
                    "name": "锦草",
                    "label": "$item.Jincao",
                    "pipeline_override": {
                        "DeliveryJobsSelectItemToFillWuling": {
                            "template": "DeliveryJobs/Jincao.png"
                        }
                    }
                }
            ],
            "default_case": "芽针"
        }
    }
}
